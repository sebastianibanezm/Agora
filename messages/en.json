    "problem": {
      "eyebrow": "01 — The problem",
      "title": "Export operations",
      "titleLine2": "run on friction",
      "lede": "Chilean exporters coordinate critical workflows across email, WhatsApp, Excel, carrier portals, and people's heads. It works — barely. And it costs real money when it doesn't.",
